{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "crons": [
          {
                  "path": "/api/cron/bot",
                  "schedule": "0 11 * * *"
          },
          {
                  "path": "/api/cron/self-heal",
                  "schedule": "0 1 * * *"
          }
    ],
    "functions": {
          "app/api/cron/bot/route.js": {
                  "maxDuration": 55,
                  "memory": 512
          },
          "app/api/og/route.js": {
                  "maxDuration": 10,
                  "memory": 512
          },
          "app/api/articles/latest/route.js": {
                  "maxDuration": 8
          },
          "app/api/articles/paginated/route.js": {
                  "maxDuration": 8
          },
          "app/api/articles/view/route.js": {
                  "maxDuration": 5
          },
          "app/api/admin/**": {
                  "maxDuration": 20
          }
    }
}
