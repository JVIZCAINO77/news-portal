{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "crons": [
    { "path": "/api/cron/bot", "schedule": "0 11 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 11 * * *" },
    { "path": "/api/cron/bot", "schedule": "0 12 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 12 * * *" },
    { "path": "/api/cron/bot", "schedule": "0 13 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 13 * * *" },
    { "path": "/api/cron/bot", "schedule": "0 14 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 14 * * *" },
    { "path": "/api/cron/bot", "schedule": "0 15 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 15 * * *" },
    { "path": "/api/cron/bot", "schedule": "0 16 * * *"  },
    { "path": "/api/cron/bot", "schedule": "30 16 * * *" },
    { "path": "/api/cron/cleanup",   "schedule": "0 23 * * *" },
    { "path": "/api/cron/fix-images","schedule": "0 2 * * *"  }
  ],

  "functions": {
    "app/api/cron/bot/route.js": {
      "maxDuration": 55,
      "memory": 512
    },
    "app/api/og/route.js": {
      "maxDuration": 10,
      "memory": 512
    },
    "app/api/articles/latest/route.js": {
      "maxDuration": 8
    },
    "app/api/articles/paginated/route.js": {
      "maxDuration": 8
    },
    "app/api/articles/view/route.js": {
      "maxDuration": 5
    },
    "app/api/admin/**": {
      "maxDuration": 20,
      "memory": 128
    },
    "app/api/cron/fix-images/route.js": {
      "maxDuration": 60,
      "memory": 256
    },
    "app/api/internalize-image/route.js": {
      "maxDuration": 30,
      "memory": 256
    }
  },

  "headers": [
    {
      "source": "/api/articles/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=600, stale-while-revalidate=1200" }
      ]
    },
    {
      "source": "/api/og",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/feed.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    }
  ]
}
